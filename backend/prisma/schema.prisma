generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING_PAYMENT
  CONFIRMED
  PICKUP_SCHEDULED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  DELAYED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  INVOICED
}

enum InvoiceStatus {
  OPEN
  PAID
  OVERDUE
  VOID
}

enum WaybillStatus {
  UNUSED
  USED
  VOID
}

enum ParcelSize {
  SMALL
  MEDIUM
  LARGE
}

enum NotificationTemplateType {
  ORDER_CONFIRMATION
  PICKUP_SCHEDULED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  DELAY_ALERT
  OTP_VERIFICATION
  DRIVER_ASSIGNMENT
  ADMIN_NEW_ORDER
}

enum VehicleType {
  MOTORCYCLE
  CAR
  VAN
  TRUCK
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  phone          String   @unique
  name           String
  surname        String
  email          String   @unique
  password       String
  isVerified     Boolean  @default(false)
  defaultAddress Json?
  isAdmin        Boolean  @default(false)
  isBusiness     Boolean  @default(false)
  companyName    String?
  passwordChangedAt DateTime?
  createdAt      DateTime @default(now())

  orders         Order[]
  bulkOrders     BulkOrder[]
  invoices       Invoice[]
  waybills       Waybill[]
  waybillBatches WaybillBatch[]

  @@map("users")
}

model Driver {
  id                String      @id @default(uuid()) @db.Uuid
  name              String
  phone             String      @unique
  email             String?     @unique
  vehicleType       VehicleType
  vehiclePlate      String?
  isActive          Boolean     @default(true)
  passwordHash      String?
  passwordChangedAt DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  orders Order[]

  @@map("drivers")
}

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  trackingNumber  String        @unique
  senderId        String        @db.Uuid
  driverId        String?       @db.Uuid
  pickupAddress   Json
  deliveryAddress Json
  parcelDetails   Json
  status          OrderStatus   @default(PENDING_PAYMENT)
  quoteAmount     Int
  paymentStatus   PaymentStatus @default(PENDING)
  receiverPhone   String
  receiverEmail   String        @default("")
  bulkOrderId     String?       @db.Uuid
  invoiceId       String?       @db.Uuid
  waybillId       String?       @unique @db.Uuid
  waybillCode     String?       @unique
  proofOfDelivery Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  sender    User                 @relation(fields: [senderId], references: [id])
  driver    Driver?              @relation(fields: [driverId], references: [id])
  bulkOrder BulkOrder?           @relation(fields: [bulkOrderId], references: [id])
  invoice   Invoice?             @relation(fields: [invoiceId], references: [id])
  waybill   Waybill?             @relation(fields: [waybillId], references: [id])
  timeline  OrderTimelineEntry[]
  payments  Payment[]
  notificationLogs NotificationLog[]

  @@map("orders")
}

model BulkOrder {
  id              String   @id @default(uuid()) @db.Uuid
  referenceNumber String   @unique
  senderId        String   @db.Uuid
  pickupAddress   Json
  createdAt       DateTime @default(now())

  sender User    @relation(fields: [senderId], references: [id])
  orders Order[]

  @@map("bulk_orders")
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String        @unique
  businessId    String        @db.Uuid
  weekStart     DateTime
  weekEnd       DateTime
  totalAmount   Int           @default(0)
  status        InvoiceStatus @default(OPEN)
  paidAt        DateTime?
  paidBy        String?       @db.Uuid
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  business User    @relation(fields: [businessId], references: [id])
  orders   Order[]

  @@unique([businessId, weekStart])
  @@map("invoices")
}

model WaybillBatch {
  id          String    @id @default(uuid()) @db.Uuid
  batchNumber String    @unique
  businessId  String    @db.Uuid
  size        Int
  notes       String?
  createdBy   String    @db.Uuid
  printedAt   DateTime?
  createdAt   DateTime  @default(now())

  business User      @relation(fields: [businessId], references: [id])
  waybills Waybill[]

  @@map("waybill_batches")
}

model Waybill {
  id         String        @id @default(uuid()) @db.Uuid
  code       String        @unique
  businessId String        @db.Uuid
  batchId    String        @db.Uuid
  status     WaybillStatus @default(UNUSED)
  orderId    String?       @unique @db.Uuid
  issuedAt   DateTime      @default(now())
  usedAt     DateTime?
  voidedAt   DateTime?
  voidReason String?

  business User         @relation(fields: [businessId], references: [id])
  batch    WaybillBatch @relation(fields: [batchId], references: [id])
  order    Order?

  @@index([businessId, status])
  @@map("waybills")
}

model OrderTimelineEntry {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @db.Uuid
  status    String
  timestamp DateTime @default(now())
  note      String?

  order Order @relation(fields: [orderId], references: [id])

  @@map("order_timeline_entries")
}

model Payment {
  id        String        @id @default(uuid()) @db.Uuid
  orderId   String        @db.Uuid
  amount    Int
  gateway   String        @default("payfast")
  reference String        @unique
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Otp {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  code      String
  purpose   String   @default("verification")
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@map("otps")
}

model NotificationLog {
  id              String                   @id @default(uuid()) @db.Uuid
  orderId         String?                  @db.Uuid
  recipientEmail  String
  messageType     NotificationTemplateType
  content         String
  sentAt          DateTime                 @default(now())
  deliveryStatus  String                   @default("sent")

  order Order? @relation(fields: [orderId], references: [id])

  @@map("notification_logs")
}
