generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING_PAYMENT
  CONFIRMED
  PICKUP_SCHEDULED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  DELAYED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ParcelSize {
  SMALL
  MEDIUM
  LARGE
}

enum NotificationTemplateType {
  ORDER_CONFIRMATION
  PICKUP_SCHEDULED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  DELAY_ALERT
  OTP_VERIFICATION
  DRIVER_ASSIGNMENT
}

enum VehicleType {
  MOTORCYCLE
  CAR
  VAN
  TRUCK
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  phone          String   @unique
  name           String
  surname        String
  email          String   @unique
  password       String
  isVerified     Boolean  @default(false)
  defaultAddress Json?
  isAdmin        Boolean  @default(false)
  createdAt      DateTime @default(now())

  orders Order[]

  @@map("users")
}

model Driver {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  phone       String      @unique
  email       String?
  vehicleType VehicleType
  vehiclePlate String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orders Order[]

  @@map("drivers")
}

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  trackingNumber  String        @unique
  senderId        String        @db.Uuid
  driverId        String?       @db.Uuid
  pickupAddress   Json
  deliveryAddress Json
  parcelDetails   Json
  status          OrderStatus   @default(PENDING_PAYMENT)
  quoteAmount     Int
  paymentStatus   PaymentStatus @default(PENDING)
  receiverPhone   String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  sender   User                 @relation(fields: [senderId], references: [id])
  driver   Driver?              @relation(fields: [driverId], references: [id])
  timeline OrderTimelineEntry[]
  payments Payment[]
  notificationLogs NotificationLog[]

  @@map("orders")
}

model OrderTimelineEntry {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @db.Uuid
  status    String
  timestamp DateTime @default(now())
  note      String?

  order Order @relation(fields: [orderId], references: [id])

  @@map("order_timeline_entries")
}

model Payment {
  id        String        @id @default(uuid()) @db.Uuid
  orderId   String        @db.Uuid
  amount    Int
  gateway   String        @default("payfast")
  reference String        @unique
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Otp {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@map("otps")
}

model NotificationLog {
  id              String                   @id @default(uuid()) @db.Uuid
  orderId         String?                  @db.Uuid
  recipientEmail  String
  messageType     NotificationTemplateType
  content         String
  sentAt          DateTime                 @default(now())
  deliveryStatus  String                   @default("sent")

  order Order? @relation(fields: [orderId], references: [id])

  @@map("notification_logs")
}
